ENGRAM_CLOUD_SECRET_KEY=change-me
ENGRAM_CLOUD_BASE_URL=http://127.0.0.1:8090
ENGRAM_CLOUD_POSTGRES_DSN=postgresql+psycopg://engram:engram@localhost:5432/engram_cloud
ENGRAM_CLOUD_ENGRAM_POSTGRES_DSN=postgresql://engram:engram@localhost:5432/engram_cloud
ENGRAM_CLOUD_GITHUB_CLIENT_ID=
ENGRAM_CLOUD_GITHUB_CLIENT_SECRET=
ENGRAM_CLOUD_DATA_DIR=./data
ENGRAM_CLOUD_ALLOWED_HOSTS=memorylayer.run,www.memorylayer.run,127.0.0.1,localhost
ENGRAM_CLOUD_SECURE_COOKIES=true
ENGRAM_CLOUD_SESSION_MAX_AGE_SECONDS=1209600
ENGRAM_CLOUD_MAX_REQUEST_BYTES=2000000
ENGRAM_CLOUD_AUTH_RATE_LIMIT_PER_MINUTE=12
ENGRAM_CLOUD_API_RATE_LIMIT_PER_MINUTE=240
